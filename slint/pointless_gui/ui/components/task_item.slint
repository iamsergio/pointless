import { Style } from "../style.slint";
import { CheckBox } from "checkbox.slint";
import { FontAwesomeButton } from "font_awesome_button.slint";

export struct TaskData {
    uuid: string,
    title: string,
    is-done: bool,
    is-important: bool,
    is-evening: bool,
    due-date: string,
    has-due-date: bool,
    tag-name: string,
    tag-color: color,
    has-notes: bool,
    is-goal: bool,
}

export struct WeekDayData {
    pretty-date: string,
    is-past: bool,
    has-tasks: bool,
    tasks: [TaskData],
}

export component TaskItem {
    in property <TaskData> task;
    callback toggle-done(string);

    property <bool> use-small-mode: root.task.is-evening;
    property <length> icon-sz: root.use-small-mode ? 18px : 26px;

    height: root.use-small-mode ? Style.task-evening-height : Style.task-height;

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 10px;
        background: root.task.is-important
            ? Style.task-important-background
            : (root.task.is-evening ? Style.task-evening-background : Style.task-background);

        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            spacing: root.use-small-mode ? 5px : 10px;

            VerticalLayout {
                alignment: center;
                width: root.icon-sz;

                if !root.task.is-goal: CheckBox {
                    checked: root.task.is-done;
                    small-variant: root.use-small-mode;
                    toggled => { root.toggle-done(root.task.uuid); }
                }

                if root.task.is-goal: FontAwesomeButton {
                    icon: "\u{f11e}";
                    icon-size: root.use-small-mode ? 14px : 18px;
                    icon-color: Style.icon-color;
                    background-color: transparent;
                    width: root.icon-sz;
                    height: root.icon-sz;
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 5px;
                alignment: center;

                Text {
                    text: root.task.title;
                    font-size: root.use-small-mode ? 12px : 16px;
                    color: root.task.is-done ? Style.task-completed-text-color : Style.task-text-color;
                    overflow: elide;
                }

                if !root.use-small-mode && root.task.has-due-date: Text {
                    text: root.task.due-date;
                    font-size: 11px;
                    color: Style.task-secondary-text-color;
                }
            }

            if root.task.tag-name != "": VerticalLayout {
                alignment: center;
                horizontal-stretch: 0;

                Rectangle {
                    border-radius: 7px;
                    background: root.task.tag-color;
                    height: 14px;
                    width: badge-inner.preferred-width;

                    badge-inner := HorizontalLayout {
                        padding-left: 7px;
                        padding-right: 7px;

                        Text {
                            text: root.task.tag-name;
                            color: #ffffff;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
