import { Style } from "../style.slint";
import { TaskItem, TaskData, WeekDayData } from "task_item.slint";
import { FontAwesomeButton } from "font_awesome_button.slint";

export component WeekView {
    in property <[WeekDayData]> days;
    callback toggle-done(string);
    callback task-clicked(string);
    callback add-task-for-day(string);

    Flickable {
        viewport-height: content.preferred-height;

        content := VerticalLayout {
            spacing: 15px;
            padding: 0px;

            for day[idx] in root.days: VerticalLayout {
                spacing: 8px;

                HorizontalLayout {
                    height: 40px;

                    Text {
                        text: day.pretty-date;
                        font-size: Style.weekday-font-size;
                        font-weight: 700;
                        color: day.is-past ? Style.task-secondary-text-color : Style.weekday-text-color;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    FontAwesomeButton {
                        icon: "\u{f067}";
                        icon-size: 16px;
                        icon-color: Style.icon-color;
                        background-color: transparent;
                        width: 40px;
                        height: 40px;
                        clicked => { root.add-task-for-day(day.date-string); }
                    }
                }

                if !day.has-tasks: Text {
                    text: "No tasks for this day.";
                    font-size: 14px;
                    color: Style.task-secondary-text-color;
                }

                for t in day.tasks: TaskItem {
                    task: t;
                    toggle-done(uuid) => { root.toggle-done(uuid); }
                    task-clicked(uuid) => { root.task-clicked(uuid); }
                }
            }
        }
    }
}
